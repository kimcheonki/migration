{
  "server": "nginx",
  "keywords": {
    "virtualhost": {
      "description": "Virtual host (server block) configuration",
      "directives": ["server", "server_name", "listen"],
      "priority": "high"
    },
    "ssl": {
      "description": "SSL/TLS configuration",
      "directives": ["ssl", "ssl_certificate", "ssl_certificate_key", "ssl_protocols", "ssl_ciphers", "ssl_session_cache"],
      "priority": "high"
    },
    "upstream": {
      "description": "Upstream server configuration for load balancing",
      "directives": ["upstream", "server", "least_conn", "ip_hash"],
      "priority": "high"
    },
    "proxy": {
      "description": "Proxy configuration",
      "directives": ["proxy_pass", "proxy_set_header", "proxy_redirect", "proxy_buffering", "proxy_connect_timeout"],
      "priority": "high"
    },
    "location": {
      "description": "Location block configuration",
      "directives": ["location", "alias", "root", "index", "try_files"],
      "priority": "medium"
    },
    "gzip": {
      "description": "Gzip compression configuration",
      "directives": ["gzip", "gzip_types", "gzip_comp_level", "gzip_min_length"],
      "priority": "medium"
    },
    "log": {
      "description": "Logging configuration",
      "directives": ["access_log", "error_log", "log_format"],
      "priority": "low"
    },
    "cache": {
      "description": "Cache configuration",
      "directives": ["proxy_cache", "proxy_cache_path", "proxy_cache_valid"],
      "priority": "medium"
    },
    "limit": {
      "description": "Rate limiting configuration",
      "directives": ["limit_req", "limit_conn", "limit_req_zone"],
      "priority": "medium"
    },
    "security": {
      "description": "Security headers and configuration",
      "directives": ["add_header", "server_tokens", "client_max_body_size"],
      "priority": "high"
    },
    "worker": {
      "description": "Worker process configuration",
      "directives": ["worker_processes", "worker_connections", "worker_rlimit_nofile"],
      "priority": "low"
    },
    "events": {
      "description": "Events block configuration",
      "directives": ["events", "use", "multi_accept"],
      "priority": "low"
    }
  }
}
